# Database Configuration
# Get your Neon PostgreSQL connection string from: https://neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech:5432/tasknest

# Authentication & Security
# Generate a secure random string for JWT signing (use: openssl rand -hex 32)
BETTER_AUTH_SECRET=your-secret-key-here-change-this-in-production

# Better Auth JWKS URL (for JWT verification)
BETTER_AUTH_JWKS_URL=http://localhost:3000/api/auth/jwks

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DAYS=7

# CORS Configuration
# Add your frontend URLs (comma-separated for multiple origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# API Configuration
API_V1_PREFIX=/api/v1

# Environment
# Options: development, staging, production
ENVIRONMENT=development

# Server Configuration
HOST=0.0.0.0
PORT=8000

# ============================================================================
# LLM Provider Configuration (Smart Chatbot)
# ============================================================================
# The chatbot supports both Groq (FREE) and OpenAI (PAID).
# Uncomment ONE or BOTH API keys below:

# Option 1: Groq API (RECOMMENDED - FREE & FAST)
# - Get free API key from: https://console.groq.com
# - Model: Llama 3.1 70B
# - Speed: 0.5-1 second response time
# - Quality: 90-95% (good for most use cases)
# - Rate Limits: 30 req/min, 14,400 req/day
# GROQ_API_KEY=gsk_your_groq_api_key_here

# Option 2: OpenAI API (PAID - BEST QUALITY)
# - Get API key from: https://platform.openai.com
# - Model: GPT-4o
# - Speed: 2-5 seconds response time
# - Quality: 99% (best accuracy, better Urdu support)
# - Cost: ~$1-5/month for personal use
# OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Provider Preference (when both keys are set)
# Options: groq (default, free) or openai (paid, better quality)
# PREFERRED_LLM_PROVIDER=groq

# ============================================================================
# How to Switch Providers:
# ============================================================================
# 1. For FREE (Groq):
#    - Uncomment GROQ_API_KEY only
#    - Comment out OPENAI_API_KEY
#
# 2. For PAID (OpenAI):
#    - Uncomment OPENAI_API_KEY only
#    - Comment out GROQ_API_KEY
#
# 3. For BOTH (with preference):
#    - Uncomment both keys
#    - Set PREFERRED_LLM_PROVIDER=groq or openai
#
# No code changes needed - just restart the server!
# ============================================================================

